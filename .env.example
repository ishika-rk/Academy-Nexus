# Copy this file to .env.local for local testing with `vercel dev`.
# In production, set these in Vercel Project Settings → Environment Variables.
# Never commit real values.

# --- Firebase Admin (server-side) ---
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=academy-nexus-89e79
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Inbound: Interview Coordinator App -> us ---
# Shared secret the Interview Coordinator App must send as the x-api-key header
# when POSTing feedback to /api/interview-feedback
INTERVIEW_FEEDBACK_API_KEY=

# --- Outbound: us -> Interview Coordinator App ---
# Where /api/send-to-interview forwards eligible students
INTERVIEW_APP_URL=
INTERVIEW_APP_API_KEY=
